# ─────────────────────────────────────────────────────────────
# Allstar Prints LLC — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# GoHighLevel webhook URL
# Found in: GHL → Automations → Webhook Trigger → Copy URL
VITE_GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_WEBHOOK_ID/webhook-trigger/YOUR_TRIGGER_ID

# Optional: separate webhook URL per form type
# If blank, all forms fall back to VITE_GHL_WEBHOOK_URL
VITE_GHL_QUOTE_WEBHOOK_URL=
VITE_GHL_CONTACT_WEBHOOK_URL=
VITE_GHL_UPLOAD_WEBHOOK_URL=
VITE_GHL_GANGSHEET_WEBHOOK_URL=

# Site URL (used for Open Graph tags) — no trailing slash
VITE_SITE_URL=https://allstarprints.com
